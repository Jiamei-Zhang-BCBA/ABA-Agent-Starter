# Database
DATABASE_URL=postgresql+asyncpg://aba:aba_secret@postgres:5432/aba_saas

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aba-vaults
MINIO_USE_SSL=false

# CORS allowed origins (comma-separated, no spaces)
# CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================================
# Claude 执行模式（二选一）
# ============================================================

# 模式选择: "cli" = 用你的 Max Plan（开发）, "api" = 用 API Key（生产）
CLAUDE_MODE=cli

# --- CLI 模式（开发阶段）---
# 使用你本机登录的 Claude Code，走 Max Plan 额度
# 确保 `claude` 命令可用（已登录）
CLAUDE_CLI_PATH=claude

# --- API 模式（部署上线时切换）---
# 取消注释并填入你的 API Key，同时把 CLAUDE_MODE 改为 api
# CLAUDE_MODE=api
# ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================================

# Skills path (容器内挂载路径，本地开发时指向 .claude/skills)
SKILLS_BASE_PATH=/app/skills
CLAUDE_MD_PATH=/app/skills/CLAUDE.md
CONFIG_MD_PATH=/app/skills/_config.md
